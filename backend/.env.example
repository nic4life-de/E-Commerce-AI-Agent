# Backend Configuration
# Copy this file to .env and fill in your credentials

# API Keys
OPENAI_API_KEY=your_openai_api_key_here

# Shopify Configuration
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_STORE_URL=your-store.myshopify.com

# WooCommerce Configuration
WOOCOMMERCE_API_KEY=your_woocommerce_api_key_here
WOOCOMMERCE_API_SECRET=your_woocommerce_api_secret_here
WOOCOMMERCE_STORE_URL=https://your-store.com

# eBay API
EBAY_API_KEY=your_ebay_api_key_here

# TikTok API
TIKTOK_API_KEY=your_tiktok_api_key_here

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Database
DATABASE_URL=sqlite:///./shop_agent.db

# Frontend
FRONTEND_URL=http://localhost:3000
